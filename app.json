{
  "expo": {
    "name": "BienStroker",
    "slug": "invenApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-bien.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon-bien.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F1E9"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-bien-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.invenApp",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Izinkan aplikasi mengakses galeri untuk memilih foto bahan."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow invenApp to access your photos.",
          "savePhotosPermission": "Allow invenApp to save photos.",
          "isAccessMediaLocationEnabled": true,
          "granularPermissions": [
            "photo"
          ]
        }
      ],
      "expo-background-task"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5fa17dc3-5942-47fc-9e5d-b4a3e3ce540d"
    },
    "extra": {
      "eas": {
        "projectId": "5fa17dc3-5942-47fc-9e5d-b4a3e3ce540d"
      }
    },
    "owner": "syhanda"
  }
}
